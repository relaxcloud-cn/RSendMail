import {
    FilledButton, TextButton, TonalButton,
    OutlinedCard, FilledCard, ElevatedCard,
    TextField, Switch, CheckBox, LinearProgressIndicator,
    ScrollView, MaterialPalette, MaterialStyleMetrics,
    MaterialTypography, MaterialText, SegmentedButton, ListTile
} from "@material";

import { ComboBox, Palette, Button, LineEdit } from "std-widgets.slint";
import { AppTheme, SendMode, SectionHeader, SwitchRow } from "./common.slint";

export component ConfigPanel inherits ScrollView {
    // Basic translations binding
    in property <string> tr-smtp-server;
    in property <string> tr-server-address;
    in property <string> tr-port;
    in property <string> tr-use-tls;
    in property <string> tr-accept-invalid-certs;
    in property <string> tr-auth-required;
    in property <string> tr-username;
    in property <string> tr-password;
    in property <string> tr-sender;
    in property <string> tr-recipient;
    in property <string> tr-recipient-hint;
    in property <string> tr-send-mode;
    in property <string> tr-eml-batch;
    in property <string> tr-single-attachment;
    in property <string> tr-dir-attachment;
    in property <string> tr-eml-directory;
    in property <string> tr-attachment-file;
    in property <string> tr-attachment-directory;
    in property <string> tr-extension;
    in property <string> tr-browse;
    in property <string> tr-email-subject;
    in property <string> tr-email-body;
    in property <string> tr-filename-hint;
    in property <string> tr-advanced-options;
    in property <string> tr-processes;
    in property <string> tr-batch-size;
    in property <string> tr-timeout;
    in property <string> tr-infinite-loop;
    in property <string> tr-repeat-count;
    in property <string> tr-keep-headers;
    in property <string> tr-modify-headers;
    in property <string> tr-envelope-cc-bcc;
    in property <string> tr-anonymize-emails;
    in property <string> tr-log-level;

    // Config Properties
    in-out property <string> smtp-server;
    in-out property <string> smtp-port-str;
    in-out property <bool> use-tls;
    in-out property <bool> accept-invalid-certs;
    in-out property <bool> auth-mode;
    in-out property <string> username;
    in-out property <string> password;
    in-out property <string> from-address;
    in-out property <string> to-address;
    
    in-out property <SendMode> send-mode;
    in-out property <string> eml-dir;
    in-out property <string> eml-extension;
    in-out property <int> eml-file-count;
    in-out property <string> attachment-path;
    in-out property <string> attachment-dir;
    in-out property <int> attachment-file-count;
    in-out property <string> subject-template;
    in-out property <string> text-template;

    in-out property <string> processes;
    in-out property <string> batch-size-str;
    in-out property <string> smtp-timeout-str;
    in-out property <bool> loop-mode;
    in-out property <string> repeat-count-str;
    in-out property <bool> keep-headers;
    in-out property <bool> modify-headers;
    in-out property <bool> envelope-cc-bcc;
    in-out property <bool> anonymize-emails;
    in-out property <string> log-level;

    callback browse-eml-dir();
    callback browse-attachment();
    callback browse-attachment-dir();

    VerticalLayout {
        spacing: 12px;
        padding-right: 8px;

        // SMTP Server Section
        OutlinedCard {
            VerticalLayout {
                padding: 20px;
                spacing: 12px;

                SectionHeader { title: root.tr-smtp-server; }

                HorizontalLayout {
                    spacing: 8px;
                    Text { text: root.tr-server-address; width: 60px; font-size: 13px; color: MaterialPalette.on_surface_variant; vertical-alignment: center; }
                    LineEdit { text <=> root.smtp-server; placeholder-text: "smtp.example.com"; horizontal-stretch: 1; }
                }

                HorizontalLayout {
                    spacing: 8px; alignment: start;
                    Text { text: root.tr-port; width: 60px; font-size: 13px; color: MaterialPalette.on_surface_variant; vertical-alignment: center; }
                    LineEdit { text <=> root.smtp-port-str; width: 60px; }
                    Button { text: "25"; clicked => { root.smtp-port-str = "25"; } }
                    Button { text: "465"; clicked => { root.smtp-port-str = "465"; root.use-tls = true; } }
                    Button { text: "587"; clicked => { root.smtp-port-str = "587"; } }
                }

                HorizontalLayout {
                    spacing: 16px; alignment: start;
                    SwitchRow { label: root.tr-use-tls; checked <=> root.use-tls; }
                    SwitchRow { label: root.tr-accept-invalid-certs; checked <=> root.accept-invalid-certs; }
                }

                SwitchRow { label: root.tr-auth-required; checked <=> root.auth-mode; }

                if root.auth-mode: HorizontalLayout {
                    spacing: 8px;
                    Text { text: root.tr-username; width: 60px; font-size: 13px; color: MaterialPalette.on_surface_variant; vertical-alignment: center; }
                    LineEdit { text <=> root.username; horizontal-stretch: 1; }
                    Text { text: root.tr-password; width: 60px; font-size: 13px; color: MaterialPalette.on_surface_variant; vertical-alignment: center; }
                    LineEdit { text <=> root.password; horizontal-stretch: 1; }
                }

                HorizontalLayout {
                    spacing: 8px;
                    Text { text: root.tr-sender; width: 60px; font-size: 13px; color: MaterialPalette.on_surface_variant; vertical-alignment: center; }
                    LineEdit { text <=> root.from-address; placeholder-text: "sender@example.com"; horizontal-stretch: 1; }
                }

                HorizontalLayout {
                    spacing: 8px;
                    Text { text: root.tr-recipient; width: 60px; font-size: 13px; color: MaterialPalette.on_surface_variant; vertical-alignment: center; }
                    LineEdit { text <=> root.to-address; placeholder-text: root.tr-recipient-hint; horizontal-stretch: 1; }
                }
            }
        }

        // Send Mode Section
        OutlinedCard {
            VerticalLayout {
                padding: 20px;
                spacing: 12px;

                SectionHeader { title: root.tr-send-mode; }

                SegmentedButton {
                    items: [ { text: root.tr-eml-batch }, { text: root.tr-single-attachment }, { text: root.tr-dir-attachment } ];
                    current-index: root.send-mode == SendMode.EmlBatch ? 0 : (root.send-mode == SendMode.SingleAttachment ? 1 : 2);
                    index-changed(idx) => {
                        if idx == 0 { root.send-mode = SendMode.EmlBatch; } 
                        else if idx == 1 { root.send-mode = SendMode.SingleAttachment; } 
                        else { root.send-mode = SendMode.DirAttachment; }
                    }
                }

                if root.send-mode == SendMode.EmlBatch: VerticalLayout {
                    spacing: 8px;
                    HorizontalLayout {
                        spacing: 8px;
                        Text { text: root.tr-eml-directory; width: 60px; font-size: 13px; color: MaterialPalette.on_surface_variant; vertical-alignment: center; }
                        LineEdit { text <=> root.eml-dir; horizontal-stretch: 1; }
                        Button { text: root.tr-browse; clicked => { root.browse-eml-dir(); } }
                    }
                    HorizontalLayout {
                        spacing: 8px; alignment: start;
                        Text { text: root.tr-extension; width: 60px; font-size: 13px; color: MaterialPalette.on_surface_variant; vertical-alignment: center; }
                        LineEdit { text <=> root.eml-extension; width: 80px; }
                        if root.eml-file-count > 0: Rectangle {
                            background: AppTheme.dark-mode ? #3A3A3C : #E5E5EA;
                            border-radius: 10px; height: 22px; width: 90px;
                            Text {
                                text: "Found: " + root.eml-file-count;
                                font-size: 11px; font-weight: 600;
                                color: AppTheme.dark-mode ? #FFFFFF : #1C1C1E;
                                horizontal-alignment: center; vertical-alignment: center;
                            }
                        }
                    }
                }

                if root.send-mode == SendMode.SingleAttachment: VerticalLayout {
                    spacing: 8px;
                    HorizontalLayout {
                        spacing: 8px;
                        Text { text: root.tr-attachment-file; width: 60px; font-size: 13px; color: MaterialPalette.on_surface_variant; vertical-alignment: center; }
                        LineEdit { text <=> root.attachment-path; horizontal-stretch: 1; }
                        Button { text: root.tr-browse; clicked => { root.browse-attachment(); } }
                    }
                    HorizontalLayout {
                        spacing: 8px;
                        Text { text: root.tr-email-subject; width: 60px; font-size: 13px; color: MaterialPalette.on_surface_variant; vertical-alignment: center; }
                        LineEdit { text <=> root.subject-template; horizontal-stretch: 1; }
                    }
                    HorizontalLayout {
                        spacing: 8px;
                        Text { text: root.tr-email-body; width: 60px; font-size: 13px; color: MaterialPalette.on_surface_variant; vertical-alignment: center; }
                        LineEdit { text <=> root.text-template; horizontal-stretch: 1; }
                    }
                }

                if root.send-mode == SendMode.DirAttachment: VerticalLayout {
                    spacing: 8px;
                    HorizontalLayout {
                        spacing: 8px;
                        Text { text: root.tr-attachment-directory; width: 60px; font-size: 13px; color: MaterialPalette.on_surface_variant; vertical-alignment: center; }
                        LineEdit { text <=> root.attachment-dir; horizontal-stretch: 1; }
                        Button { text: root.tr-browse; clicked => { root.browse-attachment-dir(); } }
                    }
                    if root.attachment-file-count > 0: HorizontalLayout {
                        alignment: start;
                        Rectangle {
                            background: AppTheme.dark-mode ? #3A3A3C : #E5E5EA;
                            border-radius: 10px; height: 22px; width: 90px;
                            Text {
                                text: "Found: " + root.attachment-file-count;
                                font-size: 11px; font-weight: 600;
                                color: AppTheme.dark-mode ? #FFFFFF : #1C1C1E;
                                horizontal-alignment: center; vertical-alignment: center;
                            }
                        }
                    }
                    HorizontalLayout {
                        spacing: 8px;
                        Text { text: root.tr-email-subject; width: 60px; font-size: 13px; color: MaterialPalette.on_surface_variant; vertical-alignment: center; }
                        LineEdit { text <=> root.subject-template; horizontal-stretch: 1; }
                    }
                    HorizontalLayout {
                        spacing: 8px;
                        Text { text: root.tr-email-body; width: 60px; font-size: 13px; color: MaterialPalette.on_surface_variant; vertical-alignment: center; }
                        LineEdit { text <=> root.text-template; horizontal-stretch: 1; }
                    }
                }
            }
        }

        // Advanced Options Section
        OutlinedCard {
            VerticalLayout {
                padding: 20px;
                spacing: 12px;

                SectionHeader { title: root.tr-advanced-options; }

                HorizontalLayout {
                    spacing: 12px; alignment: start;
                    HorizontalLayout { spacing: 4px; Text { text: root.tr-processes; font-size: 12px; color: MaterialPalette.on_surface_variant; vertical-alignment: center; } LineEdit { text <=> root.processes; width: 50px; } }
                    HorizontalLayout { spacing: 4px; Text { text: root.tr-batch-size; font-size: 12px; color: MaterialPalette.on_surface_variant; vertical-alignment: center; } LineEdit { text <=> root.batch-size-str; width: 50px; } }
                    HorizontalLayout { spacing: 4px; Text { text: root.tr-timeout; font-size: 12px; color: MaterialPalette.on_surface_variant; vertical-alignment: center; } LineEdit { text <=> root.smtp-timeout-str; width: 50px; } }
                }

                HorizontalLayout {
                    spacing: 12px; alignment: start;
                    SwitchRow { label: root.tr-infinite-loop; checked <=> root.loop-mode; }
                    HorizontalLayout {
                        spacing: 4px;
                        Text { text: root.tr-repeat-count; font-size: 12px; color: MaterialPalette.on_surface_variant; vertical-alignment: center; }
                        LineEdit { text <=> root.repeat-count-str; width: 50px; enabled: !root.loop-mode; }
                    }
                }

                if root.send-mode == SendMode.EmlBatch: HorizontalLayout {
                    spacing: 12px; alignment: start;
                    SwitchRow { label: root.tr-keep-headers; checked <=> root.keep-headers; }
                    SwitchRow { label: root.tr-modify-headers; checked <=> root.modify-headers; }
                    SwitchRow { label: root.tr-envelope-cc-bcc; checked <=> root.envelope-cc-bcc; }
                    SwitchRow { label: root.tr-anonymize-emails; checked <=> root.anonymize-emails; }
                }

                HorizontalLayout {
                    spacing: 8px; alignment: start;
                    Text { text: root.tr-log-level; font-size: 12px; color: MaterialPalette.on_surface_variant; vertical-alignment: center; }
                    ComboBox {
                        model: ["error", "warn", "info", "debug", "trace"];
                        current-index: root.log-level == "error" ? 0 : (root.log-level == "warn" ? 1 : (root.log-level == "info" ? 2 : (root.log-level == "debug" ? 3 : 4)));
                        width: 80px;
                        selected(s) => { root.log-level = s; }
                    }
                }
            }
        }
    }
}
